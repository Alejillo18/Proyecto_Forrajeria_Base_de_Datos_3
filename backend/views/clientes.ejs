<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Gestión de Clientes</title>
  <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>
</head>
<body class="bg-gray-100 p-8">

  <div class="max-w-6xl mx-auto bg-white p-6 rounded-lg shadow-md">
    <div class="flex justify-between items-center mb-6">
      <div>
        <a href="/" class="text-sm text-blue-600 hover:underline block mb-1">Volver al Menú Principal</a>
        <h1 class="text-2xl font-bold text-gray-800">Administración de Clientes</h1>
      </div>
      <span id="origen-badge" class="px-4 py-2 rounded-full text-sm font-semibold bg-gray-200 text-gray-700">
        Cargando origen...
      </span>
    </div>

    <div class="overflow-x-auto">
      <table class="min-w-full bg-white border border-gray-200 rounded-lg">
        <thead class="bg-gray-50">
          <tr>
            <th class="px-6 py-3 border-b text-left text-xs font-medium text-gray-500 uppercase">Nombre</th>
            <th class="px-6 py-3 border-b text-left text-xs font-medium text-gray-500 uppercase">DNI / CUIT</th>
            <th class="px-6 py-3 border-b text-left text-xs font-medium text-gray-500 uppercase">Email</th>
            <th class="px-6 py-3 border-b text-left text-xs font-medium text-gray-500 uppercase">Fecha Alta</th>
          </tr>
        </thead>
        <tbody id="tabla-clientes" class="divide-y divide-gray-200"></tbody>
      </table>
    </div>

    <div class="flex justify-between items-center mt-6">
      <button id="btn-prev" onclick="cambiarPagina(-1)" class="px-4 py-2 bg-blue-600 text-white rounded-md hover:bg-blue-700 disabled:opacity-50">
        Anterior
      </button>
      <span id="info-pagina" class="text-sm font-medium text-gray-700">Página 1</span>
      <button id="btn-next" onclick="cambiarPagina(1)" class="px-4 py-2 bg-blue-600 text-white rounded-md hover:bg-blue-700">
        Siguiente
      </button>
    </div>
  </div>

  <script>
    let paginaActual = 1;
    const limite = 10;

    async function cargarClientes(page) {
      try {
        const res = await fetch(`/api/clientes?page=${page}&limit=${limite}`);
        const data = await res.json();

        const badge = document.getElementById('origen-badge');
        badge.innerText = `Origen: ${data.origen}`;
        if (data.origen.includes('Redis')) {
          badge.className = "px-4 py-2 rounded-full text-sm font-semibold bg-green-100 text-green-800";
        } else {
          badge.className = "px-4 py-2 rounded-full text-sm font-semibold bg-blue-100 text-blue-800";
        }

        const tbody = document.getElementById('tabla-clientes');
        tbody.innerHTML = '';

        if (data.datos.length === 0) {
          tbody.innerHTML = `<tr><td colspan="4" class="px-6 py-4 text-center text-gray-500">No hay mas registros disponibles.</td></tr>`;
          return;
        }

        data.datos.forEach(cliente => {
          const fila = `
            <tr>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-900">${cliente.nombre_cliente}</td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">${cliente.dni_cuit}</td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">${cliente.email || 'N/C'}</td>
              <td class="px-6 py-4 whitespace-nowrap text-sm text-gray-500">${new Date(cliente.fecha_creacion).toLocaleDateString()}</td>
            </tr>
          `;
          tbody.innerHTML += fila;
        });

        document.getElementById('info-pagina').innerText = `Página ${page}`;
        document.getElementById('btn-prev').disabled = page === 1;

      } catch (error) {
        console.error('Error al cargar clientes:', error);
      }
    }

    function cambiarPagina(direccion) {
      paginaActual += direccion;
      if (paginaActual < 1) paginaActual = 1;
      cargarClientes(paginaActual);
    }

    cargarClientes(paginaActual);
  </script>
</body>
</html>